{
  "name": "@summoniq/flow",
  "productName": "SummonIQ Flow",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "deps:check": "ncu -i --format group -p bun",
    "predev": "bun run db:generate && lsof -ti:30140 | xargs kill -9 2>/dev/null || true && rm -rf .next",
    "next:dev": "next dev --turbo --port 30140",
    "dev:electron": "concurrently -n NEXT,ELECTRON \"bun run next:dev\" \"bun run electron:dev\"",
    "dev:tauri": "bunx @tauri-apps/cli dev --no-watch",
    "tauri:build": "bunx @tauri-apps/cli build",
    "tauri:icons": "bunx @tauri-apps/cli icon electron/icons/icon-1024.png -o src-tauri/icons",
    "build": "next build",
    "start": "next start --port 30140",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "electron:dev": "bunx wait-on tcp:30140 && bun run electron:start",
    "electron:start": "bunx electronmon electron/main.cjs",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:backup": "bash ./scripts/db-backup.sh",
    "db:restore": "bash ./scripts/db-restore.sh",
    "db:seed": "bun run prisma/seed.ts",
    "db:init-templates": "bun run scripts/init-templates.ts",
    "db:reset-templates": "bun run scripts/reset-templates.ts && bun run scripts/init-templates.ts",
    "env:load": "bun run scripts/load-env-to-db.ts",
    "env:setup": "bun run db:generate && bun run db:push && bun run env:load",
    "ports:sync": "bun run scripts/sync-ports.ts",
    "env:sync": "bun run scripts/sync-env.ts",
    "sync:watch": "bun run --watch lib/sync/watcher.ts",
    "icons:generate": "./scripts/generate-icons.sh",
    "rag:index": "bun run ../../_Packages_/rag/scripts/index-all.ts",
    "rag:index:type": "bun run ../../_Packages_/rag/scripts/index-by-type.ts",
    "rag:reindex": "bun run ../../_Packages_/rag/scripts/reindex-stale.ts"
  },
