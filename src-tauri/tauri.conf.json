{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SummonIQ Flow",
  "identifier": "com.summoniq.flow",
  "version": "0.1.0",
  "build": {
    "beforeDevCommand": "bun run next:dev",
    "devUrl": "http://localhost:30140",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../.next"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "SummonIQ Flow",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": true,
        "minWidth": 800,
        "minHeight": 600,
        "acceptFirstMouse": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
